{
	"build": {
			"dockerfile": "./Dockerfile",
			"context": "."
	},
	"features": {
			"ghcr.io/devcontainers/features/common-utils:2": {
					"configureZshAsDefaultShell": "true",
					"username": "vscode",
					"userUid": "1000",
					"userGid": "1000"
			},
			"ghcr.io/devcontainers/features/go:1": {
					"version": "1.23.6",
					"golangciLintVersion": "1.64.6"
			},
			"ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
	// Use Docker-in-Docker to run buildkitd as a container
	"postCreateCommand": "go mod download",
	"postStartCommand": "docker rm -f buildkitd-container || true && docker run -d --name buildkitd-container --restart=unless-stopped -p 127.0.0.1:65000:65000 --privileged moby/buildkit:latest --addr tcp://0.0.0.0:65000",
  "remoteEnv": {
    "BUILDKIT_HOST": "tcp://127.0.0.1:65000"
  },
	"runArgs": [
			"--cap-add=SYS_PTRACE",
			"--security-opt",
			"seccomp=unconfined"
	],
	"customizations": {
			"vscode": {
					"settings": {
							"go.toolsManagement.checkForUpdates": "local",
							"go.useLanguageServer": true,
							"go.gopath": "/go"
					},
					"extensions": [
							"golang.Go"
					]
			}
	},
	"remoteUser": "vscode"
}
